{
  "name": "ba-random-electron",
  "version": "0.1.0",
  "description": "仿制BA抽卡的随机点名器，基于Electron和Vue3开发",
  "author": "YunHydrogen",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.yunhydrogen.ba-random",
    "productName": "BA Random",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/image/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BA Random",
      "installerIcon": "public/image/app.ico",
      "uninstallerIcon": "public/image/app.ico",
      "uninstallDisplayName": "BA Random",
      "artifactName": "BA-Random-Setup-${version}.${ext}"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.15.0",
    "js-yaml": "^4.1.0",
    "vue": "^3.5.17",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
