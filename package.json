{
  "name": "ba-random-electron",
  "version": "1.1.1",
  "description": "仿蔚蓝档案的随机点名工具-Electron",
  "author": "HydrogenRua",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.hydrogenrua.ba-random",
    "productName": "BA Random",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "zip",
      "icon": "public/image/app.ico"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.15.0",
    "js-yaml": "^4.1.0",
    "vue": "^3.5.17",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
