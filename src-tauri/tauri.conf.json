{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KVRandom",
  "version": "26.5.3",
  "identifier": "com.mfdust.kvrandom",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["../public/image/app.ico"],
    "resources": ["../public"]
  }
}
